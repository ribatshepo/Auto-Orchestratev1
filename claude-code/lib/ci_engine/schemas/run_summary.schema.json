{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunSummary",
  "description": "Summary of a complete pipeline run, produced by StageMetricsCollector.finalize_run()",
  "type": "object",
  "required": ["run_id", "completed_at", "overall_status", "stages"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Session identifier for this run"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of run completion"
    },
    "run_sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential run number within session"
    },
    "overall_status": {
      "type": "string",
      "enum": ["success", "partial", "failure"],
      "description": "Aggregate status across all stages"
    },
    "stages": {
      "type": "object",
      "description": "Per-stage results keyed by stage name",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "duration_seconds"],
        "properties": {
          "status": { "type": "string", "enum": ["success", "partial", "failure"] },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "error_count": { "type": "integer", "minimum": 0 },
          "retry_count": { "type": "integer", "minimum": 0 },
          "error_messages": { "type": "array", "items": { "type": "string" } },
          "token_input": { "type": "integer", "minimum": 0 },
          "token_output": { "type": "integer", "minimum": 0 },
          "spec_compliance_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        }
      }
    },
    "kpis": {
      "type": "object",
      "properties": {
        "total_duration_seconds": { "type": "number", "minimum": 0 },
        "spec_compliance_score": { "type": ["number", "null"] },
        "test_coverage_pct": { "type": ["number", "null"] },
        "stage_failure_bitmap": { "type": "integer", "minimum": 0 },
        "total_error_count": { "type": "integer", "minimum": 0 },
        "improvement_delta_pct": { "type": ["number", "null"] }
      }
    },
    "improvement_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
