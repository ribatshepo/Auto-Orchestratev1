{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StageBaselines",
  "description": "Rolling baseline averages from baseline_manager.update_baselines()",
  "type": "object",
  "required": ["schema_version", "baselines"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "first_run": { "type": "boolean", "description": "True when no run summaries exist" },
    "baselines": {
      "type": "object",
      "description": "Per-stage baselines keyed by stage name",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "duration_seconds": {
            "type": "object",
            "properties": {
              "smoothed": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "raw_values": { "type": "array", "items": { "type": "number" } }
            }
          },
          "error_rate": {
            "type": "object",
            "properties": {
              "smoothed": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "retry_rate": {
            "type": "object",
            "properties": {
              "smoothed": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "success_rate": {
            "type": "object",
            "properties": {
              "smoothed": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "token_count_avg": {
            "type": "object",
            "properties": {
              "smoothed": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
